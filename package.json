{
  "name": "politiscope",
  "private": true,
  "version": "2.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "deploy": "npm run build && gh-pages -d dist",
    "polls:import:local": "cross-env POLITISCOPE_API_BASE=http://127.0.0.1:8787 node ./scripts/ingest-polls.mjs",
    "polls:import:remote": "cross-env POLITISCOPE_API_BASE=https://politiscope-api.craighow8.workers.dev node ./scripts/ingest-polls.mjs",
    "polls:health:local": "node ./scripts/check-poll-health.mjs --api-base=http://127.0.0.1:8787",
    "polls:health:remote": "node ./scripts/check-poll-health.mjs --api-base=https://politiscope-api.craighow8.workers.dev",
    "byelections:import:local": "node ./scripts/ingest-byelections.mjs --api-base=http://127.0.0.1:8787",
    "byelections:import:remote": "node ./scripts/ingest-byelections.mjs --api-base=https://politiscope-api.craighow8.workers.dev",
    "elections:intelligence:refresh:local": "node ./scripts/refresh-elections-intelligence.mjs --api-base=http://127.0.0.1:8787",
    "elections:intelligence:refresh:remote": "node ./scripts/refresh-elections-intelligence.mjs --api-base=https://politiscope-api.craighow8.workers.dev",
    "elections:mayors:refresh:local": "node ./scripts/refresh-mayors.mjs --api-base=http://127.0.0.1:8787",
    "elections:mayors:refresh:remote": "node ./scripts/refresh-mayors.mjs --api-base=https://politiscope-api.craighow8.workers.dev",
    "elections:devolved:refresh:local": "node ./scripts/refresh-devolved.mjs --api-base=http://127.0.0.1:8787",
    "elections:devolved:refresh:remote": "node ./scripts/refresh-devolved.mjs --api-base=https://politiscope-api.craighow8.workers.dev",
    "local-candidates:import:local": "node ./scripts/ingest-local-candidate-sources.mjs --api-base=http://127.0.0.1:8787",
    "local-candidates:import:remote": "node ./scripts/ingest-local-candidate-sources.mjs --api-base=https://politiscope-api.craighow8.workers.dev",
    "local-officeholders:import:local": "node ./scripts/ingest-local-officeholders.mjs --api-base=http://127.0.0.1:8787",
    "local-officeholders:import:remote": "node ./scripts/ingest-local-officeholders.mjs --api-base=https://politiscope-api.craighow8.workers.dev",
    "local-results:import:local": "node ./scripts/ingest-local-election-results.mjs --api-base=http://127.0.0.1:8787",
    "local-results:import:remote": "node ./scripts/ingest-local-election-results.mjs --api-base=https://politiscope-api.craighow8.workers.dev",
    "leader-ratings:import:local": "node ./scripts/ingest-leader-ratings.mjs --api-base=http://127.0.0.1:8787",
    "leader-ratings:import:remote": "node ./scripts/ingest-leader-ratings.mjs --api-base=https://politiscope-api.craighow8.workers.dev",
    "leader-ratings:health:local": "node ./scripts/check-leader-ratings-health.mjs --api-base=http://127.0.0.1:8787",
    "leader-ratings:health:remote": "node ./scripts/check-leader-ratings-health.mjs --api-base=https://politiscope-api.craighow8.workers.dev",
    "policy-sources:import:local": "node ./scripts/ingest-party-policies.mjs --api-base=http://127.0.0.1:8787",
    "policy-sources:import:remote": "node ./scripts/ingest-party-policies.mjs --api-base=https://politiscope-api.craighow8.workers.dev",
    "policy-sources:health:local": "node ./scripts/check-policy-sources-health.mjs --api-base=http://127.0.0.1:8787",
    "policy-sources:health:remote": "node ./scripts/check-policy-sources-health.mjs --api-base=https://politiscope-api.craighow8.workers.dev",
    "political-markets:import:remote": "node ./scripts/ingest-political-markets.mjs",
    "political-markets:health:remote": "node ./scripts/check-political-markets-health.mjs",
    "local-authority:health:local": "node ./scripts/check-local-authority-health.mjs --api-base=http://127.0.0.1:8787",
    "local-authority:health:remote": "node ./scripts/check-local-authority-health.mjs --api-base=https://politiscope-api.craighow8.workers.dev",
    "health:pre-election": "npm run build && npm run polls:health:remote && npm run local-authority:health:remote && npm run leader-ratings:health:remote"
  },
  "dependencies": {
    "framer-motion": "^11.0.0",
    "node-fetch": "^2.7.0",
    "pdf-parse": "^1.1.1",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.2.1",
    "cross-env": "^10.1.0",
    "gh-pages": "^6.3.0",
    "vite": "^5.2.0",
    "wrangler": "^4.77.0"
  }
}
